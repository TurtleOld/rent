# Django
SECRET_KEY=change-me-in-production-use-at-least-50-random-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (dj-database-url format)
DATABASE_URL=postgresql://rent:rent@postgres:5432/rent

# AI API (universal HTTP client — set to your provider)
AI_API_URL=https://your-ai-provider.example.com/v1/messages
AI_API_TOKEN=your-token-here
AI_API_MODEL=your-model-name
AI_API_TIMEOUT=60

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Storage
MEDIA_ROOT=/app/media

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS (comma-separated, for local dev)
CORS_ALLOWED_ORIGINS=http://localhost:3000
